// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("member") // admin, member
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id          String   @id @default(cuid())
  name        String
  company     String
  email       String   @unique
  phone       String?
  status      String   @default("Active") // Active, Paused, Terminated
  revenue     Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leads       Lead[]
  tasks       Task[]
  notes       Note[]
  activities  Activity[]
  reports     Report[]
}

model Lead {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String?
  company         String?
  source          String   @default("Website") // Facebook, Google, Website, Referral
  status          String   @default("New")     // New, Hot, Warm, Cold, Converted
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  assignedClientId String?
  client           Client?  @relation(fields: [assignedClientId], references: [id])
  
  activities       Activity[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  priority    String   @default("Medium") // High, Medium, Low
  status      String   @default("Todo")   // Todo, In_Progress, Done
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
}

model Note {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(cuid())
  type      String   // Email, Call, Meeting, Note
  content   String
  date      DateTime @default(now())
  
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
}

model Report {
  id        String   @id @default(cuid())
  title     String
  type      String   // Performance, Monthly, Ads
  url       String?
  createdAt DateTime @default(now())

  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}
